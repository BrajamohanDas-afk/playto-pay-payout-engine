# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=playto_pay
POSTGRES_USER=playto
POSTGRES_PASSWORD=playto
DATABASE_URL=postgres://playto:playto@postgres:5432/playto_pay

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# JWT
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# Payout simulation
PAYOUT_MAX_ATTEMPTS=3
PAYOUT_STUCK_AFTER_SECONDS=30
PAYOUT_RETRY_BASE_SECONDS=5
PAYOUT_SIMULATOR_MODE=random

# Frontend
VITE_API_BASE_URL=http://localhost:8000
